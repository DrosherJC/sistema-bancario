<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="475.0" spacing="3.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label text="NUEVA TRANSACCIÓN">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
      </Label>
      <Label text="Tipo" />
      <ComboBox fx:id="cmbTipo" prefWidth="150.0" promptText="tipo" />
      <Label text="Cuenta origen" />
      <ComboBox fx:id="cmbCuentaOrigen" prefWidth="150.0" promptText="origen" />
      <Label text="Cuenta destino" />
      <ComboBox fx:id="cmbCuentaDestino" prefWidth="150.0" promptText="destino" />
      <Label text="Monto" />
      <TextField fx:id="txfMonto" maxWidth="-Infinity" prefWidth="100.0" promptText="____" />
      <Button fx:id="btnEnviar" mnemonicParsing="false" text="Listo!">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
      <Label fx:id="lblResultado" />
      <Label text="HISTORIAL" />
      <TableView fx:id="tblTransacciones" maxWidth="-Infinity" prefHeight="200.0" prefWidth="300.0">
        <columns>
          <TableColumn prefWidth="75.0" text="Tipo" />
          <TableColumn prefWidth="75.0" text="Monto" />
            <TableColumn prefWidth="75.0" text="Fecha" />
            <TableColumn prefWidth="75.0" text="Cuenta" />
        </columns>
      </TableView>
   </children>
   <padding>
      <Insets bottom="40.0" left="50.0" right="50.0" top="20.0" />
   </padding>
</VBox>
