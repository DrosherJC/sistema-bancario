<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<AnchorPane prefHeight="400.0" prefWidth="435.0" styleClass="root-container" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.LoginController">
   <children>
      <VBox alignment="BASELINE_CENTER" layoutX="108.0" layoutY="35.0" prefHeight="330.0" prefWidth="220.0" spacing="7.5" styleClass="card-panel" AnchorPane.bottomAnchor="34.599999999999966" AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="60.0" AnchorPane.topAnchor="35.0">
         <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
         </padding>
         <children>
            <Label styleClass="page-title" text="SISTEMA BANCARIO" textAlignment="CENTER">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Label>
            <Label styleClass="form-label" text="Usuario">
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin></Label>
            <TextField fx:id="txfUsuario" prefHeight="30.0" prefWidth="178.0" styleClass="text-field" />
            <Label styleClass="form-label" text="Contraseña">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin></Label>
            <PasswordField fx:id="txfPassword" styleClass="password-field" />
            <Button fx:id="btnLogin" mnemonicParsing="false" onAction="#onLogin" styleClass="btn-primary" text="Iniciar Sesión">
               <VBox.margin>
                  <Insets top="15.0" />
               </VBox.margin></Button>
            <Button mnemonicParsing="false" onAction="#onIrARegistro" styleClass="btn-link" text="Crear una cuenta nueva">
               <VBox.margin>
                  <Insets top="8.0" />
               </VBox.margin>
            </Button>
            <Label fx:id="lblError" styleClass="error-text" textFill="RED">
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets top="20.0" />
               </padding>
            </Label>
         </children>
      </VBox>
   </children>
</AnchorPane>
