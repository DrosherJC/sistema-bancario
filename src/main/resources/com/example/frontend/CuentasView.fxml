<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="-Infinity" prefHeight="650.0" prefWidth="920.0" styleClass="root-container" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.CuentasController">
   <left>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="350.0" prefWidth="280.0" spacing="4.0" styleClass="sidebar-panel" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="form-label" text="Número de Cuenta" />
            <TextField fx:id="txfNumeroCuenta" promptText="1234567890" styleClass="text-field" />
            <Label styleClass="form-label" text="Cliente">
               <VBox.margin>
                  <Insets top="6.0" />
               </VBox.margin>
            </Label>
            <ComboBox fx:id="cmbCliente" prefWidth="200.0" promptText="Cliente" styleClass="combo-box" />
            <Label styleClass="form-label" text="Tipo">
               <VBox.margin>
                  <Insets top="6.0" />
               </VBox.margin>
            </Label>
            <ComboBox fx:id="cmbTipo" prefWidth="150.0" promptText="Tipo" styleClass="combo-box" />
            <Label styleClass="form-label" text="Saldo inicial">
               <VBox.margin>
                  <Insets top="6.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="txfSaldo" promptText="0.00" styleClass="text-field" />
            <Label styleClass="form-label" text="Estado">
               <VBox.margin>
                  <Insets top="6.0" />
               </VBox.margin>
            </Label>
            <ComboBox fx:id="cmbEstado" prefWidth="150.0" promptText="Estado" styleClass="combo-box" />
            <GridPane alignment="TOP_CENTER" hgap="10.0" vgap="10.0" maxWidth="-Infinity" minWidth="-Infinity" prefWidth="220.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="105.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="105.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="38.0" prefHeight="38.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="38.0" prefHeight="38.0" vgrow="SOMETIMES" />
               </rowConstraints>
               <children>
                  <Button fx:id="btnGuardar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onGuardar" styleClass="btn-primary, btn-compact" text="Guardar" />
                  <Button fx:id="btnEliminar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onEliminar" styleClass="btn-danger, btn-compact" text="Eliminar" GridPane.rowIndex="1" />
                  <Button fx:id="btnActualizar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onActualizar" styleClass="btn-outline, btn-compact" text="Actualizar" GridPane.columnIndex="1" />
                  <Button fx:id="btnLimpiar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#onLimpiar" styleClass="btn-ghost, btn-compact" text="Limpiar" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               </children>
               <VBox.margin>
                  <Insets top="14.0" />
               </VBox.margin>
            </GridPane>
            <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#onVolver" styleClass="btn-back" text="&lt; Volver al Dashboard">
               <VBox.margin>
                  <Insets top="18.0" />
               </VBox.margin>
            </Button>
         </children>
         <padding>
            <Insets left="30.0" right="20.0" />
         </padding>
      </VBox>
   </left>
   <right>
      <VBox alignment="CENTER" minHeight="-Infinity" prefHeight="350.0" prefWidth="620.0" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tblCuentas" maxWidth="580.0" prefHeight="260.0" prefWidth="575.0" styleClass="table-view">
               <columns>
                  <TableColumn fx:id="colId" prefWidth="45.0" text="ID" />
                  <TableColumn fx:id="colNumero" prefWidth="110.0" text="Número" />
                  <TableColumn fx:id="colCliente" prefWidth="150.0" text="Cliente" />
                  <TableColumn fx:id="colTipo" prefWidth="90.0" text="Tipo" />
                  <TableColumn fx:id="colSaldo" prefWidth="90.0" text="Saldo" />
                  <TableColumn fx:id="colEstado" prefWidth="90.0" text="Estado" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" />
         </padding>
      </VBox>
   </right>
   <top>
      <VBox alignment="CENTER" styleClass="brand-header" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="app-title" text="GESTIÓN DE CUENTAS" />
         </children>
      </VBox>
   </top>
   <padding>
      <Insets bottom="10.0" />
   </padding>
</BorderPane>
