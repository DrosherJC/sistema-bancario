<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="-Infinity" prefHeight="375.0" prefWidth="783.0" style="-fx-background-color: dffeff;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <left>
      <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="330.0" prefWidth="260.0" spacing="3.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Número de Cuenta">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <TextField fx:id="txfNumeroCuenta" alignment="CENTER" promptText="1234567890" style="-fx-background-radius: 45;" />
            <Label text="Cliente">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <ComboBox fx:id="cmbCliente" prefWidth="150.0" promptText="Cliente" style="-fx-background-radius: 45;" />
            <Label text="Tipo">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <ComboBox fx:id="cmbTipo" prefWidth="150.0" promptText="Tipo" style="-fx-background-radius: 45;" />
            <Label text="Saldo">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <TextField fx:id="txfSaldo" alignment="CENTER" promptText="____" style="-fx-background-radius: 45;" />
            <Label fx:id="cmbEstado" text="Estado">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <ComboBox fx:id="cmbEstado" prefWidth="150.0" promptText="Estado" style="-fx-background-radius: 45;" />
            <GridPane alignment="TOP_CENTER" maxWidth="-Infinity" minWidth="-Infinity" prefHeight="60.0" prefWidth="145.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
               </rowConstraints>
               <children>
                  <Button fx:id="btnGuardar" alignment="CENTER" mnemonicParsing="false" style="-fx-background-radius: 45;" text="Guardar" />
                  <Button fx:id="btnEliminar" mnemonicParsing="false" style="-fx-background-radius: 45;" text="Eliminar" GridPane.rowIndex="1" />
                  <Button fx:id="btnActualizar" mnemonicParsing="false" style="-fx-background-radius: 45;" text="Actualizar" GridPane.columnIndex="1" />
                  <Button fx:id="btnLimpiar" mnemonicParsing="false" style="-fx-background-radius: 45;" text="Limpiar" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </GridPane>
         </children>
         <padding>
            <Insets left="30.0" right="20.0" />
         </padding>
      </VBox>
   </left>
   <right>
      <VBox alignment="CENTER" minHeight="-Infinity" prefHeight="330.0" prefWidth="518.0" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tblCuentas" maxWidth="450.0" prefHeight="200.0" prefWidth="200.0">
               <columns>
                  <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
                  <TableColumn fx:id="colNumero" prefWidth="75.0" text="Número" />
                  <TableColumn fx:id="colCliente" prefWidth="75.0" text="Cliente" />
                  <TableColumn fx:id="colTipo" prefWidth="75.0" text="Tipo" />
                  <TableColumn fx:id="colSaldo" prefWidth="75.0" text="Saldo" />
                  <TableColumn fx:id="colEstado" prefWidth="75.0" text="Estado" />
               </columns>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </TableView>
            <Button fx:id="btnVolver" mnemonicParsing="false" style="-fx-background-radius: 45;" text="Volver" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" />
         </padding>
      </VBox>
   </right>
   <top>
      <Label text="GESTIÓN DE CUENTAS" textFill="RED" BorderPane.alignment="CENTER">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
         <padding>
            <Insets top="15.0" />
         </padding>
      </Label>
   </top>
   <padding>
      <Insets bottom="10.0" />
   </padding>
</BorderPane>
