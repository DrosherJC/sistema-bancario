<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="700.0" styleClass="root-container" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.frontend.UsuariosController">
   <top>
      <VBox alignment="CENTER" styleClass="brand-header" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="app-title" text="GESTIÓN DE USUARIOS Y ROLES" />
         </children>
      </VBox>
   </top>
   <center>
      <VBox alignment="CENTER" spacing="16.0" BorderPane.alignment="CENTER">
         <children>
            <TableView fx:id="tblUsuarios" prefHeight="220.0" prefWidth="400.0" styleClass="table-view">
               <columns>
                  <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                  <TableColumn fx:id="colUsername" prefWidth="180.0" text="Usuario" />
                  <TableColumn fx:id="colRol" prefWidth="150.0" text="Rol" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER" spacing="10.0" styleClass="card-panel">
               <padding>
                  <Insets bottom="10.0" left="14.0" right="14.0" top="10.0" />
               </padding>
               <children>
                  <Label styleClass="form-label" text="Nuevo rol:" />
                  <ComboBox fx:id="cmbNuevoRol" prefWidth="150.0" promptText="Rol" styleClass="combo-box" />
                  <Button fx:id="btnCambiarRol" mnemonicParsing="false" onAction="#onCambiarRol" styleClass="btn-primary" text="Cambiar Rol" />
               </children>
            </HBox>
            <Label fx:id="lblMensaje" styleClass="status-text" />
            <Button fx:id="btnVolver" mnemonicParsing="false" onAction="#onVolver" styleClass="btn-back" text="Volver al Dashboard" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="18.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
