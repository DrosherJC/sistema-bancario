<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="475.0" spacing="3.0" style="-fx-background-color: dffeff;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label text="NUEVA TRANSACCIÓN" textFill="RED">
         <font>
            <Font name="System Bold" size="15.0" />
         </font>
      </Label>
      <Label text="Tipo">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Label>
      <ComboBox fx:id="cmbTipo" prefWidth="150.0" promptText="tipo" style="-fx-background-radius: 45;" />
      <Label text="Cuenta origen">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Label>
      <ComboBox fx:id="cmbCuentaOrigen" prefWidth="150.0" promptText="origen" style="-fx-background-radius: 45;" />
      <Label text="Cuenta destino">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Label>
      <TextField fx:id="txfCuentaDestino" alignment="CENTER" maxWidth="-Infinity" prefHeight="26.0" prefWidth="150.0" promptText="##########" style="-fx-background-radius: 45;" />
      <Label text="Monto">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Label>
      <TextField fx:id="txfMonto" alignment="CENTER" maxWidth="-Infinity" prefWidth="100.0" promptText="____" style="-fx-background-radius: 45;" />
      <Button fx:id="btnEnviar" mnemonicParsing="false" style="-fx-background-radius: 45;" text="Listo!">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Label fx:id="lblResultado">
         <VBox.margin>
            <Insets top="5.0" />
         </VBox.margin>
         <padding>
            <Insets top="5.0" />
         </padding></Label>
      <Label text="HISTORIAL">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Label>
      <TableView fx:id="tblTransacciones" maxWidth="-Infinity" prefHeight="200.0" prefWidth="375.0">
        <columns>
          <TableColumn fx:id="colTipo" prefWidth="75.0" text="Tipo" />
          <TableColumn fx:id="colMonto" prefWidth="75.0" text="Monto" />
            <TableColumn fx:id="colFecha" prefWidth="75.0" text="Fecha" />
            <TableColumn fx:id="colCuenta" prefWidth="75.0" text="Cuenta" />
            <TableColumn fx:id="colReceptor" prefWidth="75.0" text="Receptor" />
        </columns>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </TableView>
      <Button fx:id="btnVolver" mnemonicParsing="false" style="-fx-background-radius: 45;" text="Volver">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Button>
   </children>
   <padding>
      <Insets bottom="40.0" left="50.0" right="50.0" top="20.0" />
   </padding>
</VBox>
